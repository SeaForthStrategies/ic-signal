# Convex
CONVEX_DEPLOYMENT=dev:your-deployment-name
CONVEX_DEPLOY_KEY=dev:your-deployment-name|your-deploy-key
NEXT_PUBLIC_CONVEX_URL=https://your-deployment.convex.cloud
NEXT_PUBLIC_CONVEX_SITE_URL=https://your-deployment.convex.site

# App auth
AUTH_EMAIL=admin@example.com
AUTH_PASSWORD_HASH=pbkdf2_sha256$...
AUTH_SECRET=replace-with-a-long-random-secret
AUTH_API_SECRET=replace-with-a-long-random-secret

# Convex JWT Auth
AUTH_JWT_ISSUER=https://your-app.example.com
AUTH_JWT_AUDIENCE=convex
AUTH_JWT_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----"
AUTH_JWKS={"keys":[]}
